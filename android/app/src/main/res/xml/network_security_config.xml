<?xml version="1.0" encoding="utf-8" ?>
<network-security-config>
    <!-- Default: All traffic must be encrypted (TLS) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext for local network device discovery (mDNS/QUIC) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">local</domain>
        <domain includeSubdomains="true">connected.local</domain>
        <ip address="10.0.0.0/8" />
        <ip address="172.16.0.0/12" />
        <ip address="192.168.0.0/16" />
        <ip address="127.0.0.1" />
    </domain-config>
</network-security-config>
