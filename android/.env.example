# Android release signing configuration
# Copy this file to .env and fill in your values
#
# To generate a keystore, run:
# keytool -genkey -v \
#   -keystore ~/connected-release.keystore \
#   -alias connected-key \
#   -keyalg RSA \
#   -keysize 2048 \
#   -validity 10000

# Keystore file password
ANDROID_KEYSTORE_PASSWORD=

# Key password (can be same as keystore password)
ANDROID_KEY_PASSWORD=

# Key alias (use 'connected-key' if you generated with the command above)
ANDROID_KEY_ALIAS=

# Path to the keystore file (relative to android/app/)
# Default: release.keystore (placed in android/app/)
ANDROID_KEYSTORE_PATH=
